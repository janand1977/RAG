   "source": [
    "\n",
    "\n",
    "# Input: [2, 1, 5, 1, 3, 2], k=3 \n",
    "\n",
    "input=  [2, 1, 5, 1, 3, 2]\n",
    "k=3 \n",
    "ws=0\n",
    "ms = 0\n",
    "sum=0\n",
    "for we in range(len(input)):\n",
    "    # print(input[i])\n",
    "    sum+= input[we]\n",
    "    if (we >= k-1):\n",
    "        ms = max(ms, sum)\n",
    "        sum -= input[ws]\n",
    "        ws+=1\n",
    "\n",
    "print(ms)"
   ]
