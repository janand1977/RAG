    "from dataclasses import dataclass\n",
    "\n",
    "\n",
    "@dataclass(frozen=True)\n",
    "class Emp:\n",
    "   id:float  # here this class acts like instance variable and not class variable\n",
    "   name:str\n",
    "\n",
    "a = Emp(100,'anand')\n",
    "b = Emp(101, 'jp')\n",
    "c = Emp(102, 'jass')\n",
    "\n",
    "mySet ={a,a,b}\n",
    "print(mySet)\n",
    "\n",
