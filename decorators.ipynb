   "source": [
    "# add a decorator\n",
    "\n",
    "\n",
    "\n",
    "def simple_logger(func):\n",
    "    def wrapper(*args,**kwargs):\n",
    "        print('Entering')\n",
    "        result = func(*args,**kwargs)\n",
    "\n",
    "        print('Exiting')\n",
    "        return result\n",
    "    return wrapper\n",
    "\n",
    "@simple_logger\n",
    "def add(a,b):\n",
    "    return a+b\n",
    "\n",
    "\n",
    "print(add(1,2))\n",
    "\n",
    "\n"
   ]
  }
 ],
